{
  "name": "maria-levi",
  "version": "0.1.0",
  "description": "marialeviphoto.com — fashion & personal brand photography portfolio",
  "license": "UNLICENSED",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "cross-env NODE_OPTIONS=\"--no-deprecation --max-old-space-size=8000\" next build",
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev",
    "devsafe": "rm -rf .next && cross-env NODE_OPTIONS=--no-deprecation next dev",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "seed": "cross-env NODE_OPTIONS=--no-deprecation tsx scripts/seed.ts",
    "db:push": "cross-env NODE_OPTIONS=--no-deprecation tsx scripts/db-push.ts",
    "seed:admin": "cross-env NODE_OPTIONS=--no-deprecation tsx scripts/users/seed-admin.ts",
    "user:create": "cross-env NODE_OPTIONS=--no-deprecation tsx scripts/users/create.ts",
    "user:list": "cross-env NODE_OPTIONS=--no-deprecation tsx scripts/users/list.ts",
    "user:reset-password": "cross-env NODE_OPTIONS=--no-deprecation tsx scripts/users/reset-password.ts",
    "user:disable": "cross-env NODE_OPTIONS=--no-deprecation tsx scripts/users/disable.ts",
    "user:enable": "cross-env NODE_OPTIONS=--no-deprecation tsx scripts/users/enable.ts",
    "user:delete": "cross-env NODE_OPTIONS=--no-deprecation tsx scripts/users/delete.ts",
    "test": "pnpm run test:int && pnpm run test:e2e",
    "test:e2e": "cross-env NODE_OPTIONS=\"--no-deprecation --import=tsx/esm\" playwright test --config=playwright.config.ts",
    "test:int": "cross-env NODE_OPTIONS=--no-deprecation vitest run --config ./vitest.config.mts",
    "prepare": "husky"
  },
  "dependencies": {
    "@payloadcms/db-postgres": "^3.84.0",
    "@payloadcms/next": "^3.84.0",
    "@payloadcms/richtext-lexical": "^3.84.0",
    "@payloadcms/ui": "^3.84.0",
    "@sentry/nextjs": "^10.51.0",
    "cross-env": "^7.0.3",
    "dotenv": "^16.4.7",
    "graphql": "^16.8.1",
    "next": "16.2.4",
    "payload": "^3.84.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sharp": "0.34.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.0",
    "@playwright/test": "1.58.2",
    "@tailwindcss/postcss": "^4.2.0",
    "@testing-library/react": "16.3.0",
    "@types/node": "^25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "4.5.2",
    "husky": "^9.1.7",
    "jsdom": "28.0.0",
    "lint-staged": "^16.4.0",
    "tailwindcss": "^4.2.0",
    "tsx": "4.21.0",
    "typescript": "5.7.3",
    "vite-tsconfig-paths": "6.0.5",
    "vitest": "4.0.18"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": "^9 || ^10"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,css}": [
      "biome check --write --no-errors-on-unmatched"
    ]
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp",
      "esbuild",
      "unrs-resolver",
      "@biomejs/biome"
    ]
  }
}

# Database (Neon Postgres)
DATABASE_URL=postgres://user:password@host/db?sslmode=require

# Payload
PAYLOAD_SECRET=change-me-to-a-64-char-random-string
PAYLOAD_PUBLIC_SERVER_URL=http://localhost:3000

# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Cloudflare R2 (S3-compatible) — fill in once buckets exist
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=marialeviphoto-media
R2_PUBLIC_URL=

# Cloudflare Images — fill in once enabled
CLOUDFLARE_IMAGES_ACCOUNT=
CLOUDFLARE_IMAGES_TOKEN=
CLOUDFLARE_IMAGES_HASH=

# Email (Resend) — fill in after domain verified
RESEND_API_KEY=
RESEND_FROM_EMAIL=hello@marialeviphoto.com
RESEND_REPLY_TO=hello@marialeviphoto.com

# Email marketing (Flodesk)
FLODESK_API_KEY=
FLODESK_FALLBACK_ZAPIER_URL=

# Analytics (loaded only after cookie consent)
NEXT_PUBLIC_GA4_ID=
NEXT_PUBLIC_PIXEL_ID=

# Sentry — fill in once project exists
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# Webhook secrets (generate random values)
REVALIDATE_SECRET=
PAYLOAD_WEBHOOK_SECRET=
LEAD_WEBHOOK_SECRET=

# Future (CRM)
HONEYBOOK_API_KEY=
